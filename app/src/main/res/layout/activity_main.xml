<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/zov_bg"
    android:padding="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="HEROKU HOST"
        android:textColor="@color/zov_yellow"
        android:textSize="30sp"
        android:textStyle="bold"
        android:gravity="center"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="mini userland with buttons"
        android:textColor="@color/zov_muted"
        android:textSize="12sp"
        android:gravity="center"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="developer: @ziwupa"
        android:textColor="@color/zov_yellow"
        android:textSize="12sp"
        android:gravity="center"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/installLinuxBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="1. INSTALL LINUX"
            android:textColor="@color/zov_bg"
            android:backgroundTint="@color/zov_yellow"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <Button
            android:id="@+id/installHerokuBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="2. INSTALL HEROKU"
            android:textColor="@color/zov_bg"
            android:backgroundTint="@color/zov_yellow"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <Button
            android:id="@+id/startBotBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="3. START BOT"
            android:textColor="@color/zov_bg"
            android:backgroundTint="@color/zov_yellow"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <Button
            android:id="@+id/terminalBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="TERMINAL"
            android:textColor="@color/zov_bg"
            android:backgroundTint="#FFF1AE"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <Button
            android:id="@+id/stopBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="STOP PROCESS"
            android:textColor="@color/zov_bg"
            android:backgroundTint="#FF6B6B"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <Button
            android:id="@+id/copyLogsBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="COPY LOGS"
            android:textColor="@color/zov_bg"
            android:backgroundTint="#FFF1AE"
            android:fontFamily="monospace"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/zov_panel"
        android:padding="12dp"
        android:layout_marginBottom="12dp">
        <TextView
            android:id="@+id/logConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting for action...\n"
            android:textColor="@color/zov_white"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="terminal input"
            android:textColorHint="@color/zov_muted"
            android:textColor="@color/zov_white"
            android:backgroundTint="@color/zov_yellow"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/sendInputBtn"
            android:layout_width="96dp"
            android:layout_height="wrap_content"
            android:text="SEND"
            android:textColor="@color/zov_bg"
            android:backgroundTint="@color/zov_yellow"
            android:fontFamily="monospace"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
