<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zov_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/menuToggleBtn"
                style="@style/ZovButtonPrimary"
                android:layout_width="52dp"
                android:text="☰"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="HEROKU HOST"
                android:textColor="@color/zov_yellow"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center_vertical" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Host panel for Linux, Heroku and long-running terminal sessions"
                android:textColor="@color/zov_white"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="developer: @ziwupa"
                android:textColor="@color/zov_muted_soft"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/versionInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="app version: loading..."
                android:textColor="@color/zov_muted_soft"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card_alt"
                android:padding="10dp"
                android:text="status: checking..."
                android:textColor="@color/zov_white"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/hostModeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_alt"
                android:padding="10dp"
                android:text="host mode: protected runtime"
                android:textColor="@color/zov_yellow"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                style="@style/ZovSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="QUICK START" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/installLinuxBtn"
                    style="@style/ZovButtonPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="1. Linux" />

                <Button
                    android:id="@+id/installHerokuBtn"
                    style="@style/ZovButtonPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="2. Heroku" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/startBotBtn"
                    style="@style/ZovButtonSoft"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="3. Start" />

                <Button
                    android:id="@+id/stopBtn"
                    style="@style/ZovButtonDanger"
                    android:layout_width="0dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Stop" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TERMINAL OUTPUT"
                android:textColor="@color/zov_muted_soft"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <Button
                android:id="@+id/followOutputBtn"
                style="@style/ZovButtonSoft"
                android:layout_width="118dp"
                android:layout_height="40dp"
                android:text="FOLLOW: ON"
                android:textSize="11sp" />

            <Button
                android:id="@+id/bottomBtn"
                style="@style/ZovButtonPrimary"
                android:layout_width="88dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="BOTTOM"
                android:textSize="11sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/logScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/logConsole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for action...\n"
                android:textColor="@color/zov_white"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:textIsSelectable="false" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <EditText
                android:id="@+id/inputField"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/zov_yellow"
                android:fontFamily="monospace"
                android:hint="send input to active process"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:textColor="@color/zov_white"
                android:textColorHint="@color/zov_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/sendInputBtn"
                style="@style/ZovButtonPrimary"
                android:layout_width="96dp"
                android:layout_marginStart="10dp"
                android:text="SEND" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionPanel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:elevation="12dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <Button
            android:id="@+id/menuCloseBtn"
            style="@style/ZovButtonPrimary"
            android:layout_width="match_parent"
            android:layout_marginBottom="12dp"
            android:text="☰ CLOSE MENU"
            android:textSize="13sp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_alt"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        style="@style/ZovSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="ACCOUNT PROFILE" />

                    <Spinner
                        android:id="@+id/sessionSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:backgroundTint="@color/zov_yellow" />

                    <Button
                        android:id="@+id/addSessionBtn"
                        style="@style/ZovButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="+ Create account profile" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card_alt"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        style="@style/ZovSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="MAINTENANCE" />

                    <Button
                        android:id="@+id/checkStatusBtn"
                        style="@style/ZovButtonSoft"
                        android:layout_width="match_parent"
                        android:text="Check status" />

                    <Button
                        android:id="@+id/repairBtn"
                        style="@style/ZovButtonSoft"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Repair runtime" />

                    <Button
                        android:id="@+id/updateHerokuBtn"
                        style="@style/ZovButtonSoft"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Update Heroku" />

                    <Button
                        android:id="@+id/reapplyPatchesBtn"
                        style="@style/ZovButtonSoft"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Reapply APK patches" />

                    <Button
                        android:id="@+id/checkUpdatesBtn"
                        style="@style/ZovButtonInfo"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Check updates" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card_alt"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        style="@style/ZovSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="TERMINAL SESSION" />

                    <Spinner
                        android:id="@+id/terminalSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:backgroundTint="@color/zov_yellow" />

                    <Button
                        android:id="@+id/addTerminalBtn"
                        style="@style/ZovButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="+ Create terminal session" />

                    <Button
                        android:id="@+id/terminalBtn"
                        style="@style/ZovButtonSoft"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Open selected terminal" />

                    <Button
                        android:id="@+id/stopTerminalBtn"
                        style="@style/ZovButtonDanger"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Stop selected terminal" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card_alt"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        style="@style/ZovSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="TOOLS" />

                    <Button
                        android:id="@+id/clearLogsBtn"
                        style="@style/ZovButtonSoft"
                        android:layout_width="match_parent"
                        android:text="Clear logs" />

                    <Button
                        android:id="@+id/copyLogsBtn"
                        style="@style/ZovButtonSoft"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Copy logs" />

                    <Button
                        android:id="@+id/supportBtn"
                        style="@style/ZovButtonInfo"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Support @herokuapk" />

                    <Button
                        android:id="@+id/githubBtn"
                        style="@style/ZovButtonInfo"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Open GitHub repo" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/forceUpdateOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2050403"
        android:clickable="true"
        android:focusable="true"
        android:padding="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="UPDATE REQUIRED"
                android:textColor="@color/zov_yellow"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="This build is outdated. Install the latest APK to continue using Heroku Host."
                android:textColor="@color/zov_white"
                android:textSize="15sp"
                android:gravity="center"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/forceUpdateBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_alt"
                android:padding="12dp"
                android:text="Update details"
                android:textColor="@color/zov_info"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/updateNowBtn"
                style="@style/ZovButtonPrimary"
                android:layout_width="match_parent"
                android:layout_marginTop="16dp"
                android:text="Update now" />

            <Button
                android:id="@+id/checkAgainBtn"
                style="@style/ZovButtonSoft"
                android:layout_width="match_parent"
                android:layout_marginTop="8dp"
                android:text="Check again" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
