<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zov_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/menuToggleBtn"
                android:layout_width="54dp"
                android:layout_height="46dp"
                android:text="☰"
                android:textColor="@color/zov_bg"
                android:backgroundTint="@color/zov_yellow"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HEROKU HOST"
                android:textColor="@color/zov_yellow"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="developer: @ziwupa"
            android:textColor="@color/zov_yellow"
            android:textSize="12sp"
            android:gravity="center"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/installLinuxBtn"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="1. DOWNLOAD LINUX"
                android:textColor="@color/zov_bg"
                android:backgroundTint="@color/zov_yellow"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <Button
                android:id="@+id/installHerokuBtn"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="2. INSTALL HEROKU"
                android:textColor="@color/zov_bg"
                android:backgroundTint="@color/zov_yellow"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <Button
                android:id="@+id/startBotBtn"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="3. START USERBOT"
                android:textColor="@color/zov_bg"
                android:backgroundTint="@color/zov_yellow"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <Button
                android:id="@+id/stopBtn"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="STOP PROCESS"
                android:textColor="@color/zov_bg"
                android:backgroundTint="#FF6B6B"
                android:fontFamily="monospace"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/logScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/zov_panel"
            android:padding="12dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/logConsole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for action...\n"
                android:textColor="@color/zov_white"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/inputField"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="terminal input"
                android:textColorHint="@color/zov_muted"
                android:textColor="@color/zov_white"
                android:backgroundTint="@color/zov_yellow"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/sendInputBtn"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:text="SEND"
                android:textColor="@color/zov_bg"
                android:backgroundTint="@color/zov_yellow"
                android:fontFamily="monospace"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionPanel"
        android:layout_width="304dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/zov_panel"
        android:elevation="12dp"
        android:padding="14dp">

        <Button
            android:id="@+id/menuCloseBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="☰ CLOSE MENU"
            android:textColor="@color/zov_bg"
            android:backgroundTint="@color/zov_yellow"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ACCOUNT PROFILE"
            android:textColor="@color/zov_yellow"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/sessionSpinner"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:backgroundTint="@color/zov_yellow"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/addSessionBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="+ CREATE ACCOUNT PROFILE"
            android:textColor="@color/zov_bg"
            android:backgroundTint="@color/zov_yellow"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <Button
            android:id="@+id/terminalBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="OPEN TERMINAL"
            android:textColor="@color/zov_bg"
            android:backgroundTint="#FFF1AE"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/copyLogsBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="COPY LOGS"
            android:textColor="@color/zov_bg"
            android:backgroundTint="#FFF1AE"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <Button
            android:id="@+id/supportBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="✈ SUPPORT @HEROKUAPK"
            android:textColor="@color/zov_bg"
            android:backgroundTint="#8BD3FF"
            android:fontFamily="monospace"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
