<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZovHost" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/zov_yellow</item>
        <item name="colorPrimaryVariant">@color/zov_yellow</item>
        <item name="colorOnPrimary">@color/zov_bg</item>
        <item name="android:statusBarColor">@color/zov_bg</item>
        <item name="android:navigationBarColor">@color/zov_bg</item>
        <item name="android:windowBackground">@color/zov_bg</item>
    </style>

    <style name="ZovButtonBase" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">46dp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="ZovButtonPrimary" parent="ZovButtonBase">
        <item name="backgroundTint">@color/zov_yellow</item>
        <item name="android:textColor">@color/zov_bg</item>
    </style>

    <style name="ZovButtonSoft" parent="ZovButtonBase">
        <item name="backgroundTint">@color/zov_yellow_soft</item>
        <item name="android:textColor">@color/zov_bg</item>
    </style>

    <style name="ZovButtonInfo" parent="ZovButtonBase">
        <item name="backgroundTint">@color/zov_info</item>
        <item name="android:textColor">@color/zov_bg</item>
    </style>

    <style name="ZovButtonDanger" parent="ZovButtonBase">
        <item name="backgroundTint">@color/zov_danger</item>
        <item name="android:textColor">@color/zov_bg</item>
    </style>

    <style name="ZovSectionTitle">
        <item name="android:textColor">@color/zov_yellow</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
</resources>
